    Input.Size = UDim2.new(0, 185, 0, 30); Input.Position = UDim2.new(0, 65, 0, 10); Input.BackgroundColor3 = Color3.fromRGB(12,12,12); Input.Text = ""; Input.PlaceholderText = "Player Name..."; Input.TextColor3 = Color3.new(1,1,1); Input.Font = Enum.Font.Gotham; Input.TextSize = 13; Input.ZIndex = 2

    local ViewBtn = Instance.new("TextButton", SlotFrame)
    ViewBtn.Size = UDim2.new(0, 185, 0, 28); ViewBtn.Position = UDim2.new(0, 65, 0, 45); ViewBtn.BackgroundColor3 = ButtonColor; ViewBtn.Text = "View Player"; ViewBtn.TextColor3 = Color3.new(1,1,1); ViewBtn.Font = Enum.Font.GothamBold; ViewBtn.TextSize = 12; ViewBtn.ZIndex = 2
    
    -- Lógica Input FocusLost e View Player
    local SlotData = {Target = nil, Viewing = false, Connection = nil}
    Input.FocusLost:Connect(function()
        local n = Input.Text:lower()
        for _, v in pairs(Players:GetPlayers()) do
            if v.Name:lower():sub(1, #n) == n or v.DisplayName:lower():sub(1, #n) == n then
                SlotData.Target = v; Input.Text = v.DisplayName
                Icon.Image = Players:GetUserThumbnailAsync(v.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150); Icon.ImageColor3 = Color3.new(1,1,1)
                break
            end
        end
    end)
    ViewBtn.MouseButton1Click:Connect(function()
        if not SlotData.Target then return end
        SlotData.Viewing = not SlotData.Viewing
        if SlotData.Viewing then
            ViewBtn.Text = "Stop View"; ViewBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
            SlotData.Connection = RunService.RenderStepped:Connect(function()
                if SlotData.Target and SlotData.Target.Character then Camera.CameraSubject = SlotData.Target.Character:FindFirstChildOfClass("Humanoid") end
            end)
        else
            ViewBtn.Text = "View Player"; ViewBtn.BackgroundColor3 = ButtonColor
            if SlotData.Connection then SlotData.Connection:Disconnect() end
            Camera.CameraSubject = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        end
    end)
end

