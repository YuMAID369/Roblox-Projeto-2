local ExecuteCopy = Instance.new("TextButton", CopySkinFrame)
ExecuteCopy.Size = UDim2.new(1, -20, 0, 35); ExecuteCopy.Position = UDim2.new(0, 10, 0, 60); ExecuteCopy.BackgroundColor3 = ButtonColor; ExecuteCopy.Text = "EXECUTE COPY"; ExecuteCopy.TextColor3 = Color3.new(1,1,1); ExecuteCopy.Font = Enum.Font.GothamBold; Instance.new("UICorner", ExecuteCopy); ExecuteCopy.ZIndex = 2

ExecuteCopy.MouseButton1Click:Connect(function()
    local TPlayer = selectedPlayerForSkin
    if not TPlayer or not TPlayer.Character then ExecuteCopy.Text = "SELECT ALVO!"; task.wait(1.5); ExecuteCopy.Text = "EXECUTE COPY"; return end
    local TChar, LChar = TPlayer.Character, LocalPlayer.Character
    local THum, LHum = TChar:FindFirstChildOfClass("Humanoid"), LChar:FindFirstChildOfClass("Humanoid")
    if THum and LHum and Remotes.Wear then
        ExecuteCopy.Text = "MORFANDO..."; 
        local successT, PDesc = pcall(function() return THum:GetAppliedDescription() end)
        local successL, LDesc = pcall(function() return LHum:GetAppliedDescription() end)
        local function SafeWear(id) if id and tonumber(id) and tonumber(id) ~= 0 then Remotes.Wear:InvokeServer(tonumber(id)) task.wait(0.3) end end
        if successL then for _, acc in ipairs(LDesc:GetAccessories(true)) do Remotes.Wear:InvokeServer(tonumber(acc.AssetId)) task.wait(0.15) end end
        Remotes.Wear:InvokeServer(0); Remotes.ChangeCharacterBody:InvokeServer({0,0,0,0,0,0})
        if successT then Remotes.ChangeCharacterBody:InvokeServer({PDesc.Torso, PDesc.RightArm, PDesc.LeftArm, PDesc.RightLeg, PDesc.LeftLeg, PDesc.Head}) end
        local SkinColor = TChar:FindFirstChildOfClass("BodyColors")
        if SkinColor then Remotes.ChangeBodyColor:FireServer(tostring(SkinColor.HeadColor)) end
        local faceId = GetFaceId(TChar)
        if faceId then SafeWear(faceId) elseif successT and PDesc.Face ~= 0 then SafeWear(PDesc.Face) end
        if successT then SafeWear(PDesc.Shirt); SafeWear(PDesc.Pants); for _, acc in ipairs(PDesc:GetAccessories(true)) do SafeWear(acc.AssetId) end end
        ExecuteCopy.Text = "SUCESSO!"; task.wait(2); ExecuteCopy.Text = "EXECUTE COPY"
    end
end)

